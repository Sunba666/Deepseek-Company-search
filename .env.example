# ===========================================
# Company Lookup - 多源API协同配置
# ===========================================
# 本项目采用"搜索-验证-补充-仲裁"架构
# 需要配置以下API以获取真实数据
# ===========================================

# ========== Flask 基础配置 ==========
FLASK_ENV=development
SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO
SESSION_COOKIE_SECURE=false

# ========== 第一层：工商信息验证 API ==========
# 用途：将公司名称解析为标准工商注册信息
# 注意：至少配置一个即可

# 天眼查 API（推荐）
# 申请地址：https://open.tianyancha.com/
# 文档：https://open.tianyancha.com/production/document
TIANYACHA_API_KEY=

# 企查查 API
# 申请地址：https://www.qcc.com/
QICHACHA_API_KEY=

# ========== 第二层：舆情搜索 API ==========
# 用途：搜索员工评价、薪资爆料、新闻动态
# 注意：至少配置一个即可

# Tavily API（推荐，免费额度）
# 申请地址：https://tavily.com/
# 免费额度：1000次/月
TAVILY_API_KEY=

# 必应搜索 API（微软认知服务）
# 申请地址：https://portal.azure.com/
# 免费额度：1000次/月
BING_API_KEY=

# ========== 第三层：司法风险 API ==========
# 用途：查询企业涉诉、失信、行政处罚等记录

# 启信宝 API
# 申请地址：https://www.qixin.com/
QIXINBAO_API_KEY=

# 裁判文书网（公开接口，无需KEY）
# https://wenshu.court.gov.cn/

# ========== AI 分析 API ==========
# 用途：矛盾点提取、深度分析报告
# 注意：DeepSeek兼容OpenAI接口

DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ========== Mock 模式说明 ==========
# 如果上述API都未配置，系统将自动切换到Mock模式
# Mock模式使用预设的示例数据，方便开发测试
# 预设公司：腾讯、阿里巴巴、字节跳动、华为、小米
